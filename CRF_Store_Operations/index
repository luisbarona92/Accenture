  <script>
    function goSlide(id, btn) {
      document.querySelectorAll('.slide').forEach(s => s.classList.remove('active'));
      document.getElementById('slide-' + id).classList.add('active');
      document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const pct = (id / 7) * 100;
      document.getElementById('progressBar').style.width = pct + '%';
      document.querySelectorAll('.slide').forEach(s => {
        s.querySelectorAll('.inner-panel').forEach((p, i) => p.classList.toggle('active', i === 0));
        s.querySelectorAll('.itab').forEach((t, i) => t.classList.toggle('active', i === 0));
      });
      window.scrollTo(0, 0);
    }

    function switchInner(id, btn) {
      const slide = btn.closest('.slide');
      slide.querySelectorAll('.inner-panel').forEach(p => p.classList.remove('active'));
      const panel = document.getElementById('inner-' + id);
      if (panel) panel.classList.add('active');
      slide.querySelectorAll('.itab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
    }

    document.querySelectorAll('.ref-card').forEach(card => {
      card.addEventListener('click', () => card.classList.toggle('flipped'));
    });

    function updateSim() {
      const lv1 = parseFloat(document.getElementById('lv1').value);
      const lv2 = parseFloat(document.getElementById('lv2').value);
      const lv3 = parseFloat(document.getElementById('lv3').value);
      document.getElementById('lv1-val').textContent = lv1 + '%';
      document.getElementById('lv2-val').textContent = lv2 + '%';
      document.getElementById('lv3-val').textContent = lv3 + '%';

      const storeType = document.querySelector('#sim-type .sim-tog-btn.active')?.textContent.trim() || 'Urban HM';
      const country   = document.querySelector('#sim-country .sim-tog-btn.active')?.textContent.trim() || 'FR + ES';

      // Multipliers by store type
      let m1 = 1.0, m2 = 1.0, m3 = 1.0;
      if (storeType === 'Peri-urban HM') { m1 = 1.08; m3 = 0.92; }
      else                               { m1 = 0.93; m3 = 1.08; }

      // Country-specific parameters
      // ES: 175 FTEs × €30,000 employer cost = €5.25M/HM
      // FR: 175 FTEs × €31,800 employer cost (gross €22,400 + 42% charges) = €5.56M/HM
      // FR+ES blended: avg €5.4M/HM
      let hm = 381, laborCost = 5400000;
      if (country === 'France only') {
        m2 *= 1.12; m3 *= 1.10; hm = 186; laborCost = 5560000;
      } else if (country === 'Spain only') {
        m1 *= 0.95; m2 *= 0.88; hm = 195; laborCost = 5250000;
      }

      const combined = Math.min(lv1 * m1 + lv2 * m2 * 0.85 + lv3 * m3 * 0.88, 34);
      const total = Math.round(combined * 10) / 10;
      document.getElementById('sim-total').textContent = total.toFixed(1) + '%';
      const ebit = Math.round((combined / 8) * 10) / 10;
      document.getElementById('sim-ebit').textContent = ebit.toFixed(1) + ' pt';
      // 175 FTEs × 40h/week = 7,000 weekly labor hours per HM
      const hours = Math.round(7000 * combined / 100);
      document.getElementById('sim-hours').textContent = '~' + hours + 'h';
      const hmVal = laborCost * combined / 100 / 1000000;
      document.getElementById('sim-value').textContent = '€' + hmVal.toFixed(1) + 'M';
      const netVal = hm * hmVal;
      const netStr = netVal >= 1000 ? (netVal / 1000).toFixed(1) + 'B' : Math.round(netVal) + 'M';
      document.getElementById('sim-network').textContent = '€' + netStr;
    }
    // Initialise on load so values are correct before first slider interaction
    document.addEventListener('DOMContentLoaded', updateSim);

    function setSimParam(btn) {
      btn.closest('.sim-toggle').querySelectorAll('.sim-tog-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      updateSim();
    }
  </script>
