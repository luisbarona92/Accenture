<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CRF Productivity Proposal Master</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{--c-navy:#001228;--c-blue:#003DA5;--c-blue2:#0055C8;--c-blue3:#2B7FE0;--c-sky:#7EC8E3;--c-ice:#C5E4F3;--c-red:#E3001B;--c-red-dim:rgba(227,0,27,.18);--c-purple:#A100FF;--glass:rgba(0,61,165,.04);--glass-h:rgba(0,61,165,.08);--glass-b:rgba(0,61,165,.13);--green:#00D084;--yellow:#FFB800;--grad-bg:#ffffff}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Space Grotesk',-apple-system,sans-serif;background:#ffffff;color:#0d1a2d;min-height:100vh;overflow-x:hidden}
    .bg-glow{position:fixed;width:700px;height:700px;border-radius:50%;filter:blur(160px);opacity:.04;pointer-events:none;z-index:0}
    .bg-g1{top:-250px;right:-150px;background:var(--c-blue);animation:f1 22s ease-in-out infinite}
    .bg-g2{bottom:-250px;left:-150px;background:var(--c-blue3);animation:f2 28s ease-in-out infinite}
    @keyframes f1{0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-60px,60px) scale(1.1)}}
    @keyframes f2{0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(60px,-60px) scale(1.1)}}
    #progressBar{position:fixed;top:0;left:0;height:3px;width:0%;background:linear-gradient(90deg,var(--c-blue),var(--c-sky));z-index:2000;transition:width .4s ease}
    header{position:sticky;top:0;padding:12px 40px;background:rgba(255,255,255,.98);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,0,0,.1);display:flex;justify-content:space-between;align-items:center;z-index:1000;gap:20px}
    .hdr-left{display:flex;align-items:center;gap:18px}
    .hdr-sep{width:1px;height:28px;background:rgba(0,0,0,.15);flex-shrink:0}
    .hdr-logo{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--c-blue)}
    .hdr-logo b{color:var(--c-red)}
    .hdr-sub{font-size:.65rem;color:var(--c-blue);text-transform:uppercase;letter-spacing:2px}
    .hdr-right{display:flex;align-items:center;gap:10px;margin-left:auto}
    .chip{display:flex;align-items:center;gap:7px;padding:6px 13px;border-radius:100px;font-size:.73rem;white-space:nowrap}
    .chip-date{background:rgba(0,61,165,.08);border:1px solid rgba(0,61,165,.2);color:rgba(0,61,165,.75)}
    .chip-live{background:rgba(227,0,27,.08);border:1px solid rgba(227,0,27,.25);color:var(--c-red);font-weight:700}
    .live-dot{width:7px;height:7px;border-radius:50%;background:var(--c-red);animation:blink 2s ease-in-out infinite}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
    .hdr-logo-crf{display:flex;align-items:center;gap:7px}
    .crf-logo-text{font-size:1.05rem;font-weight:800;letter-spacing:-.3px;color:#003DA5}
    .crf-logo-text .crf-red{color:#E3001B}
    .hdr-x{font-size:.95rem;font-weight:300;color:rgba(0,18,40,.3);margin:0 2px}
    .acc-logo-text{font-size:1.05rem;font-weight:800;letter-spacing:-.3px;color:#001228}
    .acc-logo-text .acc-purple{color:#A100FF}
    /* Gantt chart */
    .gantt-wrap{margin:12px 0;overflow-x:auto}
    .gantt{display:grid;grid-template-columns:155px repeat(8,1fr);border:1.5px solid rgba(0,61,165,.15);border-radius:12px;overflow:hidden;min-width:660px}
    .gantt-hdr-lbl{background:var(--c-navy);color:#fff;font-size:.66rem;font-weight:700;padding:8px 12px;display:flex;align-items:center;border-right:2px solid rgba(255,255,255,.12)}
    .gantt-hdr-wk{background:var(--c-navy);color:rgba(255,255,255,.8);font-size:.64rem;font-weight:700;text-align:center;padding:8px 4px;display:flex;align-items:center;justify-content:center;border-right:1px solid rgba(255,255,255,.1)}
    .gantt-track-lbl{background:rgba(0,61,165,.07);font-size:.7rem;font-weight:700;color:var(--c-navy);padding:7px 10px;border-right:2px solid rgba(0,61,165,.22);display:flex;align-items:center;gap:7px;border-bottom:1px solid rgba(0,61,165,.1)}
    .gantt-act-lbl{font-size:.64rem;color:rgba(0,18,40,.58);padding:4px 10px;border-right:2px solid rgba(0,61,165,.1);display:flex;align-items:center;border-bottom:1px solid rgba(0,61,165,.06);background:rgba(0,61,165,.01)}
    .gantt-bar-cell{padding:3px 2px;display:flex;align-items:center;border-bottom:1px solid rgba(0,61,165,.06);border-right:1px solid rgba(0,61,165,.06)}
    .gantt-bar{border-radius:20px;height:22px;display:flex;align-items:center;padding:0 10px;font-size:.64rem;font-weight:700;color:#fff;white-space:nowrap;overflow:hidden;width:100%}
    .gantt-bar.navy{background:var(--c-navy)}
    .gantt-bar.blue{background:linear-gradient(90deg,var(--c-blue),var(--c-blue2))}
    .gantt-empty{border-bottom:1px solid rgba(0,61,165,.06);border-right:1px solid rgba(0,61,165,.06)}
    .gantt-divider{grid-column:1/10;height:2px;background:rgba(0,61,165,.1)}
    .gantt-milestone-cell{display:flex;flex-direction:column;align-items:center;justify-content:center;border-bottom:1px solid rgba(0,61,165,.06);border-right:1px solid rgba(0,61,165,.06);padding:4px 2px;min-height:38px}
    .gantt-milestone-ico{font-size:.9rem;line-height:1}
    .gantt-milestone-txt{font-size:.5rem;font-weight:700;color:var(--c-blue2);text-align:center;line-height:1.3;margin-top:2px}
    .gantt-diamond{display:flex;align-items:center;justify-content:center;font-size:.75rem;color:var(--c-blue2);border-right:1px solid rgba(0,61,165,.06);min-height:26px;background:rgba(0,61,165,.02)}
    .g-badge{width:18px;height:18px;border-radius:3px;background:var(--c-navy);color:#fff;font-size:.66rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    /* CSS flag icons (for cross-browser compatibility) */
    .cflag{display:inline-flex;align-items:center;gap:4px;vertical-align:middle}
    .fbar{width:19px;height:13px;border-radius:2px;display:inline-block;flex-shrink:0;border:1px solid rgba(0,0,0,.08)}
    .fbar.es{background:linear-gradient(to bottom,#C60B1E 28%,#FFC400 28% 72%,#C60B1E 72%)}
    .fbar.fr{background:linear-gradient(to right,#002395 33%,#fff 33% 67%,#ED2939 67%)}
    /* Team pyramid */
    .pyramid-wrap{display:flex;flex-direction:column;align-items:center;gap:0;margin:0 auto;max-width:700px}
    .py-tier{display:flex;gap:16px;justify-content:center;position:relative}
    .py-tier+.py-tier{margin-top:8px}
    .py-connector{width:1px;height:16px;background:rgba(0,61,165,.2);margin:0 auto}
    .py-card{background:#fff;border:1px solid rgba(0,61,165,.14);border-radius:12px;padding:14px 18px;text-align:center;min-width:130px;box-shadow:0 2px 8px rgba(0,61,165,.07);transition:all .3s ease}
    .py-card:hover{transform:translateY(-3px);box-shadow:0 8px 20px rgba(0,61,165,.1);border-color:rgba(0,61,165,.25)}
    .py-card.top{background:linear-gradient(135deg,var(--c-blue),var(--c-navy));color:#fff;min-width:180px}
    .py-card.manager{background:linear-gradient(135deg,rgba(0,61,165,.08),rgba(0,61,165,.02));border-color:rgba(0,61,165,.2);min-width:140px}
    .py-card.consultant{min-width:110px}
    .py-card-title{font-size:.72rem;font-weight:700;margin-bottom:3px}
    .py-card.top .py-card-title{color:#fff}
    .py-card.manager .py-card-title{color:var(--c-blue)}
    .py-card-sub{font-size:.62rem;color:rgba(0,18,40,.45);line-height:1.3}
    .py-card.top .py-card-sub{color:rgba(255,255,255,.55)}
    .py-transversal{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;padding:14px 20px;background:rgba(0,61,165,.03);border:1px dashed rgba(0,61,165,.18);border-radius:12px;margin-top:12px;width:100%}
    .py-trans-card{background:#fff;border:1px solid rgba(0,61,165,.12);border-radius:9px;padding:10px 14px;text-align:center;font-size:.7rem;font-weight:600;color:var(--c-blue2)}
    .py-trans-lbl{font-size:.58rem;color:rgba(0,18,40,.4);font-weight:400;margin-top:2px}
    .py-section-label{font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:rgba(0,18,40,.35);text-align:center;margin:8px 0 4px}
    /* TimeSkipper loop */
    .ts-loop-wrap{position:relative;margin-bottom:16px}
    .ts-conn{position:absolute;top:29px;left:calc(12.5% + 18px);right:calc(12.5% + 18px);height:2px;background:linear-gradient(90deg,var(--c-navy),var(--c-blue),var(--c-sky));z-index:0;pointer-events:none}
    .ts-step{background:#fff;border:1.5px solid rgba(0,61,165,.18);border-radius:14px;padding:16px;text-align:center;position:relative;z-index:1}
    .ts-step.ts-step-close{background:linear-gradient(135deg,rgba(0,61,165,.07),rgba(0,61,165,.02));border-color:rgba(0,61,165,.3)}
    .ts-num{width:28px;height:28px;border-radius:50%;font-size:.72rem;font-weight:700;color:#fff;display:flex;align-items:center;justify-content:center;margin:0 auto 8px}
    /* Simulator */
    .sim-wrap{display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start}
    .sim-params{display:flex;flex-direction:column;gap:10px;margin-bottom:14px;padding:14px;background:rgba(0,61,165,.04);border:1px solid rgba(0,61,165,.1);border-radius:12px}
    .sim-param-row{display:flex;align-items:center;gap:12px}
    .sim-param-label{font-size:.75rem;font-weight:600;color:#001228;min-width:80px}
    .sim-toggle{display:flex;gap:4px;flex-wrap:wrap}
    .sim-tog-btn{padding:5px 11px;border:1px solid rgba(0,61,165,.2);border-radius:6px;background:transparent;font-size:.7rem;font-family:inherit;cursor:pointer;color:rgba(0,18,40,.55);transition:all .2s}
    .sim-tog-btn.active{background:var(--c-blue);border-color:var(--c-blue);color:#fff}
    .sim-levers{display:flex;flex-direction:column;gap:12px}
    .sim-lever-card{background:#fff;border:1px solid rgba(0,61,165,.12);border-radius:12px;padding:16px 18px}
    .sim-lever-header{display:flex;align-items:center;gap:10px;margin-bottom:10px}
    .sim-lever-icon{font-size:1.2rem;width:34px;height:34px;display:flex;align-items:center;justify-content:center;background:rgba(0,61,165,.06);border-radius:8px;flex-shrink:0}
    .sim-lever-name{font-size:.83rem;font-weight:700;color:#001228}
    .sim-lever-sub{font-size:.67rem;color:rgba(0,18,40,.5)}
    .sim-lever-val{margin-left:auto;font-size:1.35rem;font-weight:800;color:var(--c-blue2);min-width:48px;text-align:right;flex-shrink:0}
    .sim-range{width:100%;margin:4px 0;accent-color:var(--c-blue2)}
    .sim-range-labels{display:flex;justify-content:space-between;font-size:.62rem;color:rgba(0,18,40,.4)}
    .sim-result-panel{background:linear-gradient(145deg,#001228,#002a6a);border-radius:16px;padding:22px;color:#fff;position:sticky;top:80px}
    .sim-result-main{text-align:center;margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,.1)}
    .sim-result-num{font-size:3.2rem;font-weight:900;background:linear-gradient(135deg,#7ecfff,#b8e8ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
    .sim-result-label{font-size:.7rem;color:rgba(255,255,255,.5);margin-top:6px}
    .sim-result-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .sim-result-item{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:11px;text-align:center}
    .sim-result-item-val{font-size:1.3rem;font-weight:800;color:#7ecfff;line-height:1}
    .sim-result-item-lbl{font-size:.6rem;color:rgba(255,255,255,.45);margin-top:3px;line-height:1.3}
    /* Financials slide */
    .fin-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:16px}
    .fin-left{display:flex;flex-direction:column;gap:14px}
    .fin-phase-card{background:#fff;border:1px solid rgba(0,61,165,.14);border-radius:16px;padding:20px;box-shadow:0 2px 12px rgba(0,61,165,.07)}
    .fin-phase-card.fin-p1{border-top:4px solid var(--c-blue)}
    .fin-phase-card.fin-p2{border-top:4px solid var(--green)}
    .fin-phase-header{margin-bottom:14px}
    .fin-phase-badge{font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--c-blue);background:rgba(0,61,165,.08);border:1px solid rgba(0,61,165,.18);padding:3px 9px;border-radius:4px;display:inline-block;margin-bottom:6px}
    .fin-phase-badge-2{color:#007a4d;background:rgba(0,208,132,.1);border-color:rgba(0,208,132,.3)}
    .fin-phase-title{font-size:1rem;font-weight:700;color:#001228}
    .fin-phase-scope{font-size:.72rem;color:rgba(0,18,40,.5);margin-top:2px}
    .fin-price-row{display:flex;justify-content:space-between;align-items:center;padding:10px 14px;background:rgba(0,61,165,.04);border:1px solid rgba(0,61,165,.1);border-radius:10px;margin-bottom:12px}
    .fin-price-label{font-size:.72rem;font-weight:600;color:rgba(0,18,40,.55)}
    .fin-price-value{font-size:.9rem;font-weight:800;color:var(--c-blue)}
    .fin-price-green{color:#007a4d}
    .fin-deliverables{display:flex;flex-direction:column;gap:7px;margin-bottom:12px}
    .fin-del-item{font-size:.8rem;color:rgba(0,18,40,.65);display:flex;gap:8px;align-items:flex-start}
    .fin-why{display:flex;gap:10px;align-items:flex-start;padding:12px 14px;background:rgba(255,184,0,.08);border:1px solid rgba(255,184,0,.25);border-radius:10px;font-size:.78rem;color:rgba(0,18,40,.65);line-height:1.5}
    .fin-why-icon{flex-shrink:0;font-size:1.1rem}
    .fin-right{display:flex;flex-direction:column;gap:12px}
    /* Accenture vs Your Price */
    .fin-price-accenture{display:flex;justify-content:space-between;align-items:center;padding:9px 14px;background:rgba(0,18,40,.04);border:1px solid rgba(0,18,40,.08);border-radius:10px;margin-bottom:7px}
    .fin-price-your{display:flex;justify-content:space-between;align-items:center;padding:11px 16px;background:rgba(0,61,165,.06);border:2px solid rgba(0,61,165,.25);border-radius:10px;margin-bottom:7px}
    .fin-price-accenture .fin-price-label{font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:rgba(0,18,40,.35)}
    .fin-price-your .fin-price-label{font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--c-blue)}
    .fin-price-strike{font-size:1.05rem;font-weight:700;color:rgba(0,18,40,.22);text-decoration:line-through}
    .fin-price-your-num{font-size:1.25rem;font-weight:800;color:var(--c-blue)}
    .fin-price-tagline{font-size:.62rem;color:rgba(0,18,40,.38);margin-bottom:12px}
    /* Phase 2 future tag */
    .fin-future-tag{display:inline-block;font-size:.55rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#7c5800;background:#fff8e1;border:1px solid #f0c83a;border-radius:4px;padding:2px 7px;margin-left:6px;vertical-align:middle}
    .fin-phase-card.fin-p2{border-top:4px solid var(--green);opacity:.85}
    /* Potential value card (dark) */
    .fin-potential-card{background:linear-gradient(140deg,#06091a 0%,#0c1a3a 100%);border-radius:16px;padding:22px;color:#fff;display:flex;flex-direction:column;gap:16px;height:100%;box-sizing:border-box}
    .fin-potential-hrow{display:flex;justify-content:space-between;align-items:flex-start;gap:8px}
    .fin-potential-title{font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.15em;color:rgba(255,255,255,.5);line-height:1.55}
    .fin-potential-prelim{font-size:.52rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#d4a017;background:rgba(212,160,23,.15);border:1px solid rgba(212,160,23,.35);border-radius:4px;padding:2px 8px;white-space:nowrap;flex-shrink:0}
    .fin-potential-scope{font-size:.6rem;color:rgba(255,255,255,.35);text-transform:uppercase;letter-spacing:.1em}
    .fin-potential-range{font-size:2.3rem;font-weight:800;color:#00d084;line-height:1.1;margin-top:2px}
    .fin-potential-desc{font-size:.73rem;color:rgba(255,255,255,.72);line-height:1.6}
    .fin-potential-desc strong{color:#fff}
    .fin-potential-sub{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .fin-potential-sub-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:12px 14px}
    .fin-potential-sub-label{font-size:.57rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:rgba(255,255,255,.38);margin-bottom:5px}
    .fin-potential-sub-value{font-size:1.3rem;font-weight:800;color:#00d084}
    .fin-potential-sub-note{font-size:.6rem;color:rgba(255,255,255,.38);margin-top:2px}
    .fin-potential-ctx{font-size:.62rem;color:rgba(255,255,255,.32);border-top:1px solid rgba(255,255,255,.07);padding-top:10px;line-height:1.55}
    /* Accenture redesign */
    .acc-hero{background:linear-gradient(145deg,#06091a,#0c1240);border-radius:18px;padding:30px;color:#fff;position:relative;overflow:hidden;margin-bottom:16px}
    .acc-hero::before{content:'';position:absolute;top:-40%;right:-10%;width:380px;height:380px;background:radial-gradient(circle,rgba(161,0,255,.22),transparent 65%);pointer-events:none}
    .acc-hero::after{content:'';position:absolute;bottom:-30%;left:-10%;width:280px;height:280px;background:radial-gradient(circle,rgba(0,61,165,.2),transparent 65%);pointer-events:none}
    .acc-hero-inner{position:relative;z-index:1}
    .acc-stats-row{display:flex;gap:24px;flex-wrap:wrap;margin-bottom:20px}
    .acc-stat{text-align:center;flex:1;min-width:100px}
    .acc-stat-num{font-size:2.8rem;font-weight:900;background:linear-gradient(135deg,#A100FF,#cc66ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
    .acc-stat-lbl{font-size:.66rem;color:rgba(255,255,255,.5);margin-top:4px;line-height:1.3}
    .acc-proof-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;position:relative;z-index:1}
    .acc-proof-card{border:1px solid rgba(161,0,255,.25);border-radius:12px;padding:18px;background:rgba(161,0,255,.05);transition:all .3s}
    .acc-proof-card:hover{background:rgba(161,0,255,.1);border-color:rgba(161,0,255,.4)}
    .acc-proof-icon{font-size:1.4rem;margin-bottom:8px}
    .acc-proof-title{font-size:.84rem;font-weight:700;color:#fff;margin-bottom:5px}
    .acc-proof-text{font-size:.72rem;color:rgba(255,255,255,.6);line-height:1.5}
    .acc-intel-wrap{display:flex;flex-direction:column;gap:14px}
    .acc-intel-item{display:grid;grid-template-columns:3px 1fr;gap:14px;align-items:start}
    .acc-intel-bar{width:3px;background:linear-gradient(180deg,#A100FF,rgba(161,0,255,.2));border-radius:2px;min-height:50px}
    .acc-intel-body{}
    .acc-intel-tag{font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:#A100FF;background:rgba(161,0,255,.08);border:1px solid rgba(161,0,255,.2);padding:2px 8px;border-radius:4px;display:inline-block;margin-bottom:5px}
    .acc-intel-title{font-size:.9rem;font-weight:700;color:#001228;margin-bottom:4px}
    .acc-intel-text{font-size:.8rem;color:rgba(0,18,40,.6);line-height:1.55}
    .acc-capability-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px}
    .acc-cap-card{border:1px solid rgba(0,61,165,.12);border-radius:12px;padding:16px;background:#fff;transition:all .3s;display:flex;gap:12px;align-items:flex-start}
    .acc-cap-card:hover{border-color:rgba(161,0,255,.25);background:rgba(161,0,255,.02)}
    .acc-cap-ico{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,#A100FF,#7B00CC);display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;box-shadow:0 3px 10px rgba(161,0,255,.3)}
    .acc-cap-title{font-size:.85rem;font-weight:700;color:#001228;margin-bottom:3px}
    .acc-cap-text{font-size:.74rem;color:rgba(0,18,40,.55);line-height:1.45}
    .acc-closing{background:linear-gradient(145deg,#06091a,#0c1240);border-radius:16px;padding:30px 40px;text-align:center;position:relative;overflow:hidden}
